{
  "name": "alert-bot",
  "version": "0.0.3",
  "description": "Adds data to the DHT.",
  "scripts": {
    "start": "npm run civildefense",
    "local": "node ./index.js --externalBaseURL http://localhost:3000/kdht/",
    "ki1r0y": "node ./index.js --externalBaseURL https://ki1r0y.com/kdht/",
    "civildefense": "node ./index.js --externalBaseURL https://civildefense.io/kdht/",
    "radio-stations": "node ./index.js --radio-stations --externalBaseURL https://civildefense.io/kdht/"
  },
  "exports": {
    ".": "./index.js"
  },
  "type": "module",
  "keywords": [
    "DHT",
    "pub/sub",
    "data",
    "alert",
    "post"
  ],
  "author": "howard.stearns@gmail.com",
  "license": "MIT",
  "overrides": {
    "log4js": "^6.9.1"
  },
  "dependencies": {
    "@axona/protocol": "github:axona-net/axona-protocol#v2.14.0",
    "@roamhq/wrtc": "^0.10.0",
    "@yz-social/kdht": "^0.1.49",
    "image-to-uri": "^1.0.0",
    "s2js": "^1.44.0",
    "uuid": "^13.0.0",
    "yargs": "^18.0.0"
  }
}
